(ns tests.test-parity-extensions
  "Focused tests for Malli parity gap closers added after the core parity pass."
  (:require [basilisp.test :refer [deftest is testing]]
            [balli.core :as b]
            [balli.experimental :as exp]
            [balli.generator :as bg]
            [balli.inspect :as inspect]
            [balli.integrations :as integ]
            [balli.provider :as bp]
            [balli.transform :as bt]
            [balli.util :as u]))

(deftest provider-requiredness-and-map-of-knobs
  (testing ":optional-threshold marks common optional keys without invalidating samples"
    (is (= [:map [:id :int]
            [:name {:optional true :balli.provider/common true} :string]]
           (bp/provide [{:id 1 :name "a"}
                        {:id 2 :name "b"}
                        {:id 3}]
                       {:optional-threshold 0.6}))))
  (testing ":prefer-map-of false keeps record-shaped output for dict samples"
    (is (= [:map ["a" {:optional true} :int]
            ["b" {:optional true} :int]
            ["c" {:optional true} :int]]
           (bp/provide [{"a" 1 "b" 2} {"c" 3}]
                       {:map-of-threshold 2
                        :prefer-map-of false}))))
  (testing "provider reports expose validation evidence"
    (let [report (bp/provide-report [{:id 1} {:id 2}]
                                    {:closed-maps true})]
      (is (= 2 (:samples report)))
      (is (= 1.0 (:confidence report)))
      (is (true? (:valid? report)))
      (is (true? (b/validate (:schema report) {:id 1}))))))

(deftest util-entry-surgery
  (is (= [:map [:id :int] [:name :string]]
         (u/set-entry [:map [:id :int]] :name :string)))
  (is (= [:map [:id [:string {:min 1}]]]
         (u/update-entry [:map [:id :string]] :id
                         (fn [s] [s {:min 1}]))))
  (is (= [:map [:user/id :int]]
         (u/rename-keys [:map [:id :int]] {:id :user/id})))
  (is (= [:map [:id :int]]
         (u/transform-entries
          [:map [:id :int] [:debug :boolean]]
          (fn [entry]
            (when-not (= :debug (:key entry)) entry)))))
  (is (= :int (get (u/path-map [:map [:id :int]]) [:id])))
  (is (= [:map [:id :string]]
         (u/update-at [:map [:id :int]] [:id] (fn [_] :string))))
  (let [d (u/diff [:map [:id :int]]
                  [:map [:id :string] [:name {:optional true} :string]])]
    (is (= [{:path [:name] :schema :string}] (:added d)))
    (is (= [{:path [:id] :from :int :to :string}] (:changed d)))))

(deftest generator-combinators-and-shrink-trace
  (is (= 42 (bg/generate* (bg/return 42) {:seed 1})))
  (is (contains? #{:a :b}
                 (bg/generate* (bg/elements [:a :b]) {:seed 2})))
  (is (= "7" (bg/generate* (bg/fmap str (bg/return 7)) {:seed 0})))
  (is (= "xxx"
         (bg/generate*
          (bg/bind (bg/return 3)
                   (fn [n] (bg/return (apply str (repeat n "x")))))
          {:seed 0})))
  (let [trace (bg/shrink-trace [:int {:min 0}] 10)]
    (is (= 10 (first trace)))
    (is (every? #(b/validate [:int {:min 0}] %) trace)))
  (is (true? (:valid? (bg/check [:map [:id :int]]
                                 [:map [:id :int]]
                                 {:iterations 10 :seed 1}))))
  (is (true? (:valid? (bg/check-roundtrip [:int {:min 0 :max 10}]
                                          (bt/string-transformer)
                                          {:iterations 10 :seed 1})))))

(deftest coercion-and-function-ergonomics
  (let [schema [:map [:id :int]]
        t (bt/string-transformer)
        report (b/coercion-report schema {:id "7"} t)]
    (is (= {:id 7} (:decoded report)))
    (is (true? (:valid? report)))
    (is (true? (b/coerce? schema {:id "7"} t))))
  (is (true? (b/roundtrip? :int "5" (bt/string-transformer))))
  (let [wrapped (b/wrap-function [:=> [:cat :int] :int] inc)]
    (is (= 2 (wrapped 1))))
  (is (= {:type :=> :arities [{:min 1 :arity 1 :input [:cat :int]
                               :output :int :max 1}]}
         (b/function-contract [:=> [:cat :int] :int]))))

(deftest experimental-analysis
  (let [schema [:map [:id :int] [:tags [:vector :keyword]]]
        cov (exp/coverage schema)]
    (is (= 4 (:paths cov)))
    (is (= 2 (:max-depth cov)))
    (is (= 1 (get (:types cov) :map 0)))
    (is (some #(= [:tags 0] (:path %)) (exp/leaf-paths schema))))
  (is (= {:id #{}
          :user #{:id}}
         (exp/dependency-graph {:id :int
                                :user [:map [:id :id]]})))
  (is (= :additive
         (exp/migration-impact [:map [:id :int]]
                               [:map [:id :int] [:name :string]])))
  (is (pos? (:risk-count (exp/risk-report [:or :int :string])))))

(deftest integration-and-inspection-helpers
  (is (= :int (integ/annotation-schema python/int)))
  (is (= [:vector :any] (integ/annotation-schema python/list)))
  (is (true? ((integ/validator [:map [:id :int]]) {:id 1})))
  (is (= {:id 1} ((integ/coercer [:map [:id :int]]
                                 (bt/string-transformer))
                  {:id "1"})))
  (is (true? (:valid? (integ/coercion-report :int "1"
                                             (bt/string-transformer)))))
  (is (= {:id 1} (integ/assert-valid [:map [:id :int]] {:id 1})))
  (is (true? (inspect/valid-schema? [:map [:id :int]])))
  (is (false? (inspect/valid-schema? [:ref :missing/ref])))
  (is (seq (inspect/problems [:ref :missing/ref]))))

(deftest parity-extension-fuzz-stress
  (doseq [seed (range 60)]
    (let [samples (mapv (fn [i]
                          (cond-> {:id i}
                            (<= (mod i 4) (mod seed 4)) (assoc :name (str "n" i))))
                        (range 1 6))
          schema (bp/provide samples {:optional-threshold 0.5
                                      :closed-maps true})
          schema* (-> schema
                      (u/set-entry :active :boolean)
                      (u/update-entry :id (fn [s] [:and s [:>= 0]]))
                      (u/rename-keys {:active :enabled}))
          value (assoc (first samples) :enabled true)
          g (bg/fmap #(assoc % :enabled true)
                     (bg/generator (u/dissoc schema* :enabled) {:seed seed}))]
      (is (every? #(b/validate schema %) samples))
      (is (true? (:valid? (bp/provide-report samples {:closed-maps true}))))
      (is (true? (b/validate schema* value)))
      (is (true? (:valid? (b/coercion-report [:map [:id :int]]
                                             {:id (str seed)}
                                             (bt/string-transformer)))))
      (is (map? (u/diff schema schema*)))
      (is (empty? (inspect/problems schema*)))
      (is (map? (exp/coverage schema*)))
      (is (keyword? (exp/migration-impact schema schema*)))
      (is (true? (:valid? (bg/check schema* g {:iterations 3 :seed seed}))))
      (is (true? (b/validate schema* (bg/generate* g {:seed seed})))))))
