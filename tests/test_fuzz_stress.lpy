(ns tests.test-fuzz-stress
  "Deterministic broad stress coverage over Balli's public surfaces.

  This is intentionally not Hypothesis: it uses Python random.Random with fixed
  seeds so failures are reproducible in ordinary `basilisp test` output."
  (:import datetime random)
  (:require [basilisp.json :as json]
            [basilisp.test :refer [deftest is testing]]
            [balli.core :as b]
            [balli.dev :as dev]
            [balli.error :as be]
            [balli.generator :as bg]
            [balli.json-schema :as js]
            [balli.openapi :as openapi]
            [balli.plantuml :as plantuml]
            [balli.provider :as bp]
            [balli.registry :as reg]
            [balli.swagger :as swagger]
            [balli.transform :as bt]))

(def ^:private leaf-schemas
  [:any :nil :string :int :float :double :number :boolean :keyword :symbol :uuid
   :time/instant :time/local-date-time :time/local-date :time/local-time :time/duration
   int? string? boolean? keyword? uuid? pos-int? nat-int? neg-int? number? inst?
   [:> -10] [:>= 0] [:< 10] [:<= 5] [:not= :forbidden]
   [:enum :red :green :blue]
   [:= :fixed]])

(def ^:private invalid-values
  [nil true false 0 1 -1 1.5 "" "x" :kw 'sym [] [1 "x"] {} {:x "x"} #{} #{1}])

(defn- choice
  [rnd xs]
  (nth xs (.randint rnd 0 (dec (count xs)))))

(defn- ex-type
  [f]
  (try
    (f)
    nil
    (catch python/Exception e
      (:type (ex-data e)))))

(defn- json-contains?
  [x needle]
  (not= -1 (.find (json/write-str x) needle)))

(defn- maybe-props
  [rnd]
  (if (zero? (.randint rnd 0 3))
    {:title (str "fuzz-" (.randint rnd 0 999))}
    {}))

(declare gen-schema)

(defn- gen-entry
  [rnd depth k]
  (let [s (gen-schema rnd depth)]
    (if (zero? (.randint rnd 0 4))
      [k {:optional true} s]
      [k s])))

(defn- gen-map-schema
  [rnd depth]
  (let [n (.randint rnd 1 4)
        entries (mapv #(gen-entry rnd depth (keyword (str "k" %))) (range n))
        props (cond-> (maybe-props rnd)
                (zero? (.randint rnd 0 2)) (assoc :closed true))
        with-props (if (seq props) (into [:map props] entries) (into [:map] entries))]
    (if (zero? (.randint rnd 0 3))
      (conj with-props [:balli.core/default [:map-of :keyword :any]])
      with-props)))

(defn- gen-seqex
  [rnd depth]
  (case (.randint rnd 0 5)
    0 [:cat :int [:* :string]]
    1 [:catn [:n :int] [:s :string]]
    2 [:alt :int :string]
    3 [:altn [:n :int] [:s :string]]
    4 [:repeat {:min 0 :max 3} :int]
    5 [:schema (gen-schema rnd depth)]))

(defn- gen-local-registry-schema
  [rnd depth]
  (let [inner (gen-schema rnd depth)
        local {:fuzz/id :int
               :fuzz/name :string
               :fuzz/node [:maybe [:map
                                   [:id :fuzz/id]
                                   [:children [:vector [:ref :fuzz/node]]]]]}]
    [:schema {:registry local}
     (choice rnd [[:map [:id :fuzz/id] [:name :fuzz/name]]
                  [:ref :fuzz/node]
                  [:vector inner]])]))

(defn- gen-schema
  [rnd depth]
  (if (<= depth 0)
    (choice rnd leaf-schemas)
    (case (.randint rnd 0 13)
      0 (choice rnd leaf-schemas)
      1 [:maybe (gen-schema rnd (dec depth))]
      2 [:vector (gen-schema rnd (dec depth))]
      3 [:set {:max 1} (gen-schema rnd (dec depth))]
      4 [:tuple (gen-schema rnd (dec depth)) (gen-schema rnd (dec depth))]
      5 [:or (gen-schema rnd (dec depth)) (gen-schema rnd (dec depth))]
      6 [:and (gen-schema rnd (dec depth))]
      7 [:map-of :keyword (gen-schema rnd (dec depth))]
      8 (gen-map-schema rnd (dec depth))
      9 [:multi {:dispatch :kind}
         [:a [:map [:kind [:= :a]] [:v (gen-schema rnd (dec depth))]]]
         [:b [:map [:kind [:= :b]] [:v (gen-schema rnd (dec depth))]]]
         [:balli.core/default [:map [:kind :keyword]]]]
      10 (gen-seqex rnd (dec depth))
      11 (gen-local-registry-schema rnd (dec depth))
      12 [:schema (gen-schema rnd (dec depth))]
      13 [:map [:created :time/instant] [:ttl :time/duration]])))

(defn- stress-one!
  [s seed]
  (let [so (b/schema s)
        t (bt/transformer (bt/json-transformer)
                          (bt/time-transformer)
                          (bt/string-transformer))
        v (bg/generate so {:seed seed})
        parsed (b/parse so v)
        unparsed (when-not (b/invalid? parsed) (b/unparse so parsed))]
    (is (= (b/form so) (b/walk so (b/schema-walker identity))))
    (is (map? (js/transform so)))
    (is (= v (bg/generate so {:seed seed})))
    (is (true? (b/validate so v)) (str "generated value validates for " (pr-str s)))
    (is (nil? (b/explain so v)))
    (is (nil? (be/humanize (b/explain so v))))
    (is (false? (b/invalid? parsed)))
    (is (true? (b/validate so unparsed)))
    ;; Transformers are lenient; this checks broad traversal/coder safety.
    (b/decode so v t)
    (b/encode so v t)
    (doseq [bad (take 5 (drop (mod seed (count invalid-values))
                              (cycle invalid-values)))]
      (let [valid? (b/validate so bad)
            explained (b/explain so bad)]
        (is (boolean? valid?))
        (when explained
          (is (some? (be/humanize explained))))))))

(deftest generated-schema-fuzz-stress
  (doseq [seed (range 24)]
    (testing (str "schema-seed " seed)
      (let [rnd (random/Random seed)
            s (gen-schema rnd 3)]
        (stress-one! s seed)))))

(deftest mutable-default-registry-stress
  (let [old (reg/default-registry)]
    (try
      (doseq [i (range 20)]
        (let [k (keyword "stress" (str "s" i))
              form (if (even? i) :int :string)]
          (reg/register! k form)
          (is (true? (b/validate k (bg/generate form {:seed i}))))))
      (finally
        (reg/set-default-registry! old)))))

(deftest registry-shadowing-and-recursion-fuzz
  (doseq [seed (range 24)]
    (let [leaf (if (even? seed) :int :string)
          other (if (even? seed) :string :int)
          value (bg/generate leaf {:seed seed})
          bad (bg/generate other {:seed (+ seed 100)})
          r (reg/registry {:fuzz/value other
                           :fuzz/node [:maybe [:map
                                               [:v :fuzz/value]
                                               [:kids {:optional true}
                                                [:vector [:ref :fuzz/node]]]]]})
          local [:schema {:registry {:fuzz/value leaf
                                     :fuzz/node [:maybe [:map
                                                         [:v :fuzz/value]
                                                         [:kids {:optional true}
                                                          [:vector [:ref :fuzz/node]]]]]}}
                 [:map
                  [:direct :fuzz/value]
                  [:refed [:ref :fuzz/value]]
                  [:tree [:ref :fuzz/node]]]]
          good {:direct value
                :refed value
                :tree {:v value :kids [{:v value}]}}
          bad-v (assoc good :direct bad)
          so (b/schema local {:registry r})]
      (is (true? (b/validate so good)) (str "local shadow failed seed " seed))
      (is (false? (b/validate so bad-v)))
      (is (nil? (b/explain so good)))
      (is (map? (js/transform so)))
      (is (not (b/invalid? (b/parse so good))))
      (is (= good (b/unparse so (b/parse so good))))
      (let [generated (bg/generate so {:seed seed :size 6})]
        (is (true? (b/validate so generated)))))))

(deftest transformer-composition-fuzz
  (let [schemas [[:map [:n :int] [:flag :boolean] [:tags [:set :keyword]]]
                 [:vector :int]
                 [:map-of :keyword :int]
                 [:or :int :string]
                 [:multi {:dispatch :kind}
                  [:a [:map [:kind [:= :a]] [:n :int]]]
                  [:b [:map [:kind [:= :b]] [:s :string]]]]
                 [:map [:created :time/instant] [:ttl :time/duration]]]
        raws [{:n "42" :flag "true" :tags ["a" "b"]}
              ["1" "2" "3"]
              {"a" "1" "b" "2"}
              "7"
              {:kind :a :n "9"}
              {:created "2024-06-01T12:00:00+00:00" :ttl "PT15M"}]
        t (bt/transformer (bt/json-transformer)
                          (bt/time-transformer)
                          (bt/string-transformer)
                          (bt/collection-transformer))]
    (doseq [i (range 36)]
      (let [idx (mod i (count schemas))
            s (nth schemas idx)
            raw (nth raws idx)
            decoded (b/decode s raw t)]
        (is (true? (b/validate s decoded))
            (str "decoded value did not validate for " s " -> " decoded))
        (is (some? (b/encode s decoded t)))))))

(deftest seqex-parse-unparse-fuzz
  (let [cases [[[:cat :int [:* :string]] [1 "a" "b"]]
               [[:catn [:n :int] [:tail [:* :string]]] [1 "a" "b"]]
               [[:alt :int :string] ["x"]]
               [[:altn [:n :int] [:s :string]] [2]]
               [[:repeat {:min 1 :max 3} :int] [1 2]]
               [[:cat [:schema [:orn [:n :int] [:s :string]]] [:? :boolean]]
                [1 true]]
               [[:cat [:schema [:map [:x :int]]] [:* [:schema [:or :int :string]]]]
                [{:x 1} 2 "a"]]]]
    (doseq [seed (range 42)]
      (let [[s v] (nth cases (mod seed (count cases)))
            parsed (b/parse s v)]
        (is (false? (b/invalid? parsed)) (str "parse failed for " s))
        (is (= v (b/unparse s parsed)) (str "unparse mismatch for " s))
        (is (true? (b/validate s v)))
        (is (some? (b/explain s (conj v :bad))))))))

(deftest function-instrumentation-fuzz
  (let [scenarios [{:schema [:=> [:cat :int] :int]
                    :f inc
                    :check (fn [w _schema]
                             (is (= 2 (w 1)))
                             (is (= :balli.core/invalid-input
                                    (ex-type #(w "x")))))}
                   {:schema [:=> [:cat :int :int] :int]
                    :f +
                    :check (fn [w _schema]
                             (is (= 3 (w 1 2)))
                             (is (= :balli.core/invalid-arity
                                    (ex-type #(w 1)))))}
                   {:schema [:=> [:cat :int [:* :int]] :int]
                    :f (fn [& xs] (apply + xs))
                    :check (fn [w _schema]
                             (is (= 10 (w 1 2 3 4)))
                             (is (= :balli.core/invalid-input
                                    (ex-type #(w 1 "x")))))}
                   {:schema [:=> [:cat :int] :int
                             [:fn (fn [[args ret]] (= ret (inc (first args))))]]
                    :f inc
                    :check (fn [w schema]
                             (is (= 2 (w 1)))
                             (let [bad (b/instrument {:schema schema} dec)]
                               (is (= :balli.core/invalid-guard
                                      (ex-type #(bad 1))))))}
                   {:schema [:=> [:cat :int] :string]
                    :f inc
                    :check (fn [w _schema]
                             (is (= :balli.core/invalid-output
                                    (ex-type #(w 1)))))}
                   {:schema [:function
                             [:=> [:cat :int] :int]
                             [:=> [:cat :int :int] :int]]
                    :f (fn ([x] (inc x)) ([x y] (+ x y)))
                    :check (fn [w _schema]
                             (is (= 2 (w 1)))
                             (is (= 3 (w 1 2)))
                             (is (= :balli.core/invalid-arity
                                    (ex-type #(w 1 2 3))))) }]]
    (doseq [seed (range 60)]
      (let [{:keys [schema f check]} (nth scenarios (mod seed (count scenarios)))
            w (b/instrument {:schema schema} f)]
        (check w schema)))))

(deftest dev-instrumentation-stress
  (dev/stop!)
  (dev/capture-fail!)
  (let [atoms (mapv (fn [i] (atom (fn [x] (+ x i)))) (range 5))]
    (try
      (doseq [[i f] (map-indexed vector atoms)]
        (dev/register! (keyword "fuzz.dev" (str "f" i))
                       f
                       [:=> [:cat :int] :int]))
      (doseq [round (range 12)]
        (dev/start!)
        (doseq [[i f] (map-indexed vector atoms)]
          (is (= (+ round i) (@f round)))
          (is (= :balli.core/invalid-input
                 (ex-type #(@f (str round))))))
        (dev/stop!)
        (doseq [[i f] (map-indexed vector atoms)]
          (is (= (+ round i) (@f round)))))
      (is (= (* 12 (count atoms)) (count (dev/uncapture-fail!))))
      (finally
        (dev/stop!)
        (doseq [i (range 5)]
          (dev/unregister! (keyword "fuzz.dev" (str "f" i))))))))

(deftest export-json-serializable-fuzz
  (let [schemas [:int
                 [:string {:min 1 :max 8}]
                 [:map [:id :int] [:tags {:optional true} [:set :keyword]]]
                 [:or :int :string]
                 [:orn [:n :int] [:s :string]]
                 [:schema {:registry {:fuzz/tree [:maybe [:map
                                                           [:id :int]
                                                           [:kids {:optional true}
                                                            [:vector [:ref :fuzz/tree]]]]]}}
                  [:ref :fuzz/tree]]
                 [:multi {:dispatch :kind}
                  [:a [:map [:kind [:= :a]] [:n :int]]]
                  [:balli.core/default [:map [:kind :keyword]]]]]]
    (doseq [seed (range 42)]
      (let [s (nth schemas (mod seed (count schemas)))
            js-out (js/transform s)
            openapi-body (openapi/request-body s {:content-type (str "application/x-" seed)})
            openapi-resp (openapi/response s {:description (str "seed " seed)})
            openapi-param (openapi/parameter "q" "query" s {:required false})
            swagger-resp (swagger/response s {:description (str "seed " seed)})
            swagger-body (swagger/parameter "body" "body" s)
            swagger-query (swagger/parameter "q" "query" s {:required false})
            content-type (first (keys (get openapi-body "content")))
            resp-content-type (first (keys (get openapi-resp "content")))
            openapi-body-schema (get-in openapi-body ["content" content-type "schema"])
            openapi-resp-schema (get-in openapi-resp ["content" resp-content-type "schema"])
            openapi-param-schema (get openapi-param "schema")
            swagger-resp-schema (get swagger-resp "schema")
            swagger-body-schema (get swagger-body "schema")
            swagger-query-schema (get swagger-query "schema")
            plant (plantuml/transform s)]
        (is (= js-out (json/read-str (json/write-str js-out))))
        (is (= openapi-body (json/read-str (json/write-str openapi-body))))
        (is (= openapi-resp (json/read-str (json/write-str openapi-resp))))
        (is (= openapi-param (json/read-str (json/write-str openapi-param))))
        (is (= swagger-resp (json/read-str (json/write-str swagger-resp))))
        (is (= swagger-body (json/read-str (json/write-str swagger-body))))
        (is (= swagger-query (json/read-str (json/write-str swagger-query))))
        (doseq [schema [openapi-body-schema openapi-resp-schema openapi-param-schema]]
          (is (nil? (get schema "components"))))
        (doseq [schema [swagger-resp-schema swagger-body-schema swagger-query-schema]]
          (is (nil? (get schema "definitions"))))
        (doseq [fragment [openapi-body openapi-resp openapi-param]]
          (is (false? (json-contains? fragment "#/definitions/")))
          (when (get fragment "components")
            (is (true? (json-contains? fragment "#/components/schemas/")))))
        (is (false? (json-contains? (dissoc swagger-query "definitions")
                                     "\"definitions\"")))
        (when (get openapi-body "components")
          (is (some? (get-in openapi-body ["components" "schemas"]))))
        (when (get openapi-resp "components")
          (is (some? (get-in openapi-resp ["components" "schemas"]))))
        (when (get openapi-param "components")
          (is (some? (get-in openapi-param ["components" "schemas"]))))
        (when (get swagger-resp "definitions")
          (is (map? (get swagger-resp "definitions"))))
        (when (get swagger-body "definitions")
          (is (map? (get swagger-body "definitions"))))
        (when (get swagger-query "definitions")
          (is (map? (get swagger-query "definitions"))))
        (is (.startswith plant "@startuml"))))))

(defn- provider-samples
  [seed]
  (case (mod seed 8)
    0 [seed (inc seed) (+ seed 2)]
    1 [(str "s" seed) (str "t" seed) nil]
    2 [{:id seed :name (str "n" seed)}
       {:id (inc seed)}
       {:id (+ seed 2) :name (str "m" seed)}]
    3 [[seed (inc seed)] [] [(+ seed 2)]]
    4 [#{:a :b} #{:c}]
    5 [{(keyword (str "k" seed)) seed
        (keyword (str "j" seed)) (inc seed)}
       {(keyword (str "z" seed)) (+ seed 2)}]
    6 [[seed (str seed)] [(inc seed) (str (inc seed))]]
    7 [{:kind :a :n seed}
       {:kind :b :s (str seed)}
       {:kind :a :n (inc seed)}]))

(deftest provider-inference-fuzz
  (doseq [seed (range 72)]
    (let [samples (provider-samples seed)
          opts {:infer-tuples (zero? (mod seed 2))
                :infer-enums (zero? (mod seed 3))
                :enum-threshold 4
                :map-of-threshold 2}
          schema (bp/provide samples opts)]
      (doseq [sample samples]
        (is (true? (b/validate schema sample))
            (str "provider inferred schema did not validate sample "
                 schema " <- " sample))))))
