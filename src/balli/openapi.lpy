(ns balli.openapi
  "OpenAPI 3 export helpers built on balli.json-schema.

  `schema` exports a Balli schema as an OpenAPI Schema Object, moving JSON
  Schema definitions under components/schemas and rewriting refs. `openapi`
  wraps schemas into a minimal OpenAPI document."
  (:require [balli.json-schema :as json-schema]))

(defn- rewrite-refs
  [x]
  (cond
    (map? x)
    (into {}
          (map (fn [[k v]]
                 [k (if (and (= "$ref" k) (string? v) (.startswith v "#/definitions/"))
                      (.replace v "#/definitions/" "#/components/schemas/" 1)
                      (rewrite-refs v))]))
          x)

    (vector? x) (mapv rewrite-refs x)
    (set? x) (set (map rewrite-refs x))
    (seq? x) (mapv rewrite-refs x)
    :else x))

(defn schema
  "Return an OpenAPI 3 schema object. Reached refs are emitted under
  {\"components\" {\"schemas\" ...}} and $ref values point at
  #/components/schemas/..."
  ([s] (schema s {}))
  ([s opts]
   (let [out (json-schema/transform s opts)
         defs (get out "definitions")
         out (rewrite-refs (dissoc out "definitions"))]
     (if (seq defs)
       (assoc out "components" {"schemas" (rewrite-refs defs)})
       out))))

(defn- split-schema
  [s opts]
  (let [sch (schema s opts)]
    [(dissoc sch "components") (get sch "components")]))

(defn openapi
  "Build a minimal OpenAPI 3.1 document.
  opts:
    :info  string-keyed info map, default {\"title\" \"Balli API\" \"version\" \"1.0.0\"}
    :paths string-keyed paths map, default {}
    :components extra components map merged with generated schemas."
  ([s] (openapi s {}))
  ([s opts]
   (let [sch (schema s opts)
         generated (get sch "components")
         root (dissoc sch "components")
         components (merge-with merge generated (:components opts))]
     (cond-> {"openapi" "3.1.0"
              "info" (or (:info opts) {"title" "Balli API" "version" "1.0.0"})
              "paths" (or (:paths opts) {})
              "components" (merge-with merge
                                       {"schemas" {"Root" root}}
                                       components)}
       (:servers opts) (assoc "servers" (:servers opts))))))

(defn request-body
  "OpenAPI requestBody object for schema `s`."
  ([s] (request-body s {}))
  ([s opts]
   (let [[sch components] (split-schema s opts)]
     (cond-> {"required" (not (false? (:required opts)))
              "content" {(or (:content-type opts) "application/json")
                         {"schema" sch}}}
       components (assoc "components" components)))))

(defn response
  "OpenAPI response object for schema `s`."
  ([s] (response s {}))
  ([s opts]
   (let [[sch components] (split-schema s opts)]
     (cond-> {"description" (or (:description opts) "OK")
              "content" {(or (:content-type opts) "application/json")
                         {"schema" sch}}}
       components (assoc "components" components)))))

(defn parameter
  "OpenAPI parameter object for a scalar schema."
  [name in s & [opts]]
  (let [opts (or opts {})
        [sch components] (split-schema s opts)]
    (cond-> {"name" name
             "in" in
             "required" (not (false? (:required opts)))
             "schema" sch}
      components (assoc "components" components))))
